## ─── Document Structure ──────────────────────────────────────────────────────

snippet doc "Full document skeleton" b
\documentclass[12pt,a4paper]{${1:article}}

\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage[english]{babel}
\usepackage{amsmath, amssymb, amsthm}
\usepackage{graphicx}
\usepackage{hyperref}
\usepackage{geometry}
\geometry{margin=1in}

\title{${2:Title}}
\author{${3:Author}}
\date{${4:\today}}

\begin{document}
\maketitle
${0}
\end{document}
endsnippet

snippet pack "usepackage" b
\usepackage${1:[${2:options}]}{${3:package}}
endsnippet

snippet beg "begin{} / end{}" bA
\begin{$1}
	${0}
\end{$1}
endsnippet

## ─── Sections ────────────────────────────────────────────────────────────────

snippet sec "section" b
\section{${1:Section Title}}
${0}
endsnippet

snippet ssec "subsection" b
\subsection{${1:Subsection Title}}
${0}
endsnippet

snippet sssec "subsubsection" b
\subsubsection{${1:Title}}
${0}
endsnippet

snippet para "paragraph" b
\paragraph{${1:Title}}
${0}
endsnippet

## ─── Math Environments ───────────────────────────────────────────────────────

snippet mk "Inline math" wA
$${1}$${0}
endsnippet

snippet dm "Display math" bA
\[
	${1}
\]
${0}
endsnippet

snippet eq "equation" b
\begin{equation}
	${1}
	\label{eq:${2}}
\end{equation}
${0}
endsnippet

snippet eql "equation (no label)" b
\begin{equation*}
	${1}
\end{equation*}
${0}
endsnippet

snippet ali "align" b
\begin{align}
	${1} &= ${2} \\\\
	${0}
\end{align}
endsnippet

snippet ali* "align*" b
\begin{align*}
	${1} &= ${2} \\\\
	${0}
\end{align*}
endsnippet

snippet gat "gather" b
\begin{gather*}
	${1} \\\\
	${0}
\end{gather*}
endsnippet

snippet cas "cases" w
\begin{cases}
	${1} & ${2} \\\\
	${0}
\end{cases}
endsnippet

## ─── Theorem-like Environments ───────────────────────────────────────────────

snippet thm "theorem" b
\begin{theorem}[${1:name}]
	${0}
\end{theorem}
endsnippet

snippet lem "lemma" b
\begin{lemma}
	${0}
\end{lemma}
endsnippet

snippet prop "proposition" b
\begin{proposition}
	${0}
\end{proposition}
endsnippet

snippet cor "corollary" b
\begin{corollary}
	${0}
\end{corollary}
endsnippet

# snippet def "definition" b
# \begin{definition}[${1:name}]
# 	${0}
# \end{definition}
# endsnippet

snippet rem "remark" b
\begin{remark}
	${0}
\end{remark}
endsnippet

snippet prf "proof" b
\begin{proof}
	${0}
\end{proof}
endsnippet

snippet exm "example" b
\begin{example}
	${0}
\end{example}
endsnippet

## ─── Lists ───────────────────────────────────────────────────────────────────

snippet item "itemize" b
\begin{itemize}
\item 
${0}
\end{itemize}
endsnippet

snippet enum "enumerate" b
\begin{enumerate}
	\item ${1}
	${0}
\end{enumerate}
endsnippet

snippet desc "description" b
\begin{description}
	\item[${1:label}] ${2}
	${0}
\end{description}
endsnippet

snippet ii "\item" bA
\item
${0}
endsnippet

## ─── Figures & Tables ────────────────────────────────────────────────────────

snippet fig "figure" b
\begin{figure}[${1:htbp}]
	\centering
	\includegraphics[width=${2:0.8}\linewidth]{${3:filename}}
	\caption{${4:Caption}}
	\label{fig:${5:label}}
\end{figure}
${0}
endsnippet

snippet tab "tabular" b
\begin{table}[${1:htbp}]
	\centering
	\caption{${2:Caption}}
	\label{tab:${3:label}}
	\begin{tabular}{${4:ccc}}
		\hline
		${5} & ${6} & ${7} \\\\
		\hline
		${0}
		\hline
	\end{tabular}
\end{table}
endsnippet

## ─── Math Operators & Symbols ────────────────────────────────────────────────

snippet frac "fraction" iA
\frac{${1:num}}{${2:den}}${0}
endsnippet

snippet // "fraction (auto)" iA
\frac{${1:num}}{${2:den}}${0}
endsnippet

snippet sq "square root" iA
\sqrt{${1}}${0}
endsnippet

snippet sqn "nth root" iA
\sqrt[${1:n}]{${2}}${0}
endsnippet

snippet sum "sum" w
\sum_{${1:i=0}}^{${2:\infty}} ${0}
endsnippet

snippet prod "product" w
\prod_{${1:i=1}}^{${2:n}} ${0}
endsnippet

snippet int "integral" w
\int_{${1:-\infty}}^{${2:\infty}} ${3} \, d${4:x}${0}
endsnippet

snippet iint "double integral" w
\iint_{${1:D}} ${2} \, d${3:A}${0}
endsnippet

snippet lim "limit" w
\lim_{${1:n} \to ${2:\infty}} ${0}
endsnippet

snippet limsup "limsup" w
\limsup_{${1:n} \to ${2:\infty}} ${0}
endsnippet

snippet ooo "\infty" iA
\infty
endsnippet

snippet => "\implies" iA
\implies
endsnippet

snippet =< "\impliedby" iA
\impliedby
endsnippet

#snippet iff "\iff" iA
#\iff
#endsnippet

snippet != "not equal" iA
\neq
endsnippet

snippet <= "\leq" iA
\leq
endsnippet

snippet >= "\geq" iA
\geq
endsnippet

snippet << "\ll" iA
\ll
endsnippet

snippet >> "\gg" iA
\gg
endsnippet

snippet ~~ "\approx" iA
\approx
endsnippet

