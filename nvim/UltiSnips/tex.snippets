snippet def "defbox environment" b
\begin{defbox}{${1:Title}}
${0}
\end{defbox}
endsnippet

## ─── Bibliography ────────────────────────────────────────────────────────────

snippet bib "bibliography" b
\bibliographystyle{${1:plain}}
\bibliography{${2:references}}
endsnippet

snippet bibitem "bibitem" b
\bibitem{${1:key}}
${2:Author},
\textit{${3:Title}},
${4:Journal/Publisher},
${5:Year}.
${0}
endsnippet
