endsnippet

snippet ref "ref" i
\ref{${1}}${0}
endsnippet

snippet eqref "eqref" i
\eqref{eq:${1}}${0}
endsnippet

snippet cite "cite" i
\cite{${1}}${0}
endsnippet

snippet citet "citet" i
\citet{${1}}${0}
endsnippet

snippet href "href" i
